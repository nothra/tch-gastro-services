# ─────────────────────────────────────────────────────────────────────────────
# Factory OpenTelemetry – Token-, Kosten- und Nutzungs-Telemetrie
# ─────────────────────────────────────────────────────────────────────────────
#
# Idee & Anstoß: Rene Lengwinat (Teams, 2026-06-17) – das Team prüft AI-Gateways
# zur Reduktion der Anthropic-Abhängigkeit; OTEL "sollte bei jeder Factory im
# Bauchladen enthalten sein". Tensorix als möglicher EU-Host für Non-Anthropic-
# Modelle via OpenCode.
#
# Diese Datei ist ein BEISPIEL und default AUS. Aktivieren durch Sourcen, bevor
# die Pipeline läuft:
#     set -a; source config/otel.env.example; set +a
#     bash scripts/run-pipeline.sh 42
# Oder die Werte in die Shell-/CI-Umgebung übernehmen. Niemals echte Tokens
# committen – diese Datei enthält nur Platzhalter.
#
# Verifiziert gegen: https://code.claude.com/docs/en/monitoring-usage
# Die Telemetrie ist CLIENT-SEITIG und wird unabhängig vom Backend emittiert
# (direkter API-Key, Bedrock, Vertex, Foundry ODER AI-Gateway mit Non-Anthropic-
# Modell). Token-Metriken bleiben exakt; der USD-Kostenwert ist eine Schätzung,
# sobald Non-Anthropic-Pricing greift – authoritative Kosten kommen vom Gateway.
# ─────────────────────────────────────────────────────────────────────────────

# Master-Schalter – ohne dies wird nichts emittiert
export CLAUDE_CODE_ENABLE_TELEMETRY=1

# Exporter – nur konfigurieren, was gebraucht wird
export OTEL_METRICS_EXPORTER=otlp        # otlp | prometheus | console | none
export OTEL_LOGS_EXPORTER=otlp           # otlp | console | none

# OTLP-Ziel: Gateway oder Collector-Endpoint
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc  # grpc | http/protobuf | http/json
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Authentifizierung (falls der Endpoint sie verlangt) – Token aus der Umgebung,
# nicht hier hartkodieren
export OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer ${OTEL_TOKEN:-REPLACE_ME}"

# Factory-Attribution: jede Metrik trägt service.name + Team; Session→Task joinbar
export OTEL_RESOURCE_ATTRIBUTES="service.name=dm-factory,team.id=${FACTORY_TEAM:-unset}"
export OTEL_METRICS_INCLUDE_SESSION_ID=true

# Export-Intervalle: Default 60s (metrics) / 5s (logs). Fürs Debugging kürzer:
# export OTEL_METRIC_EXPORT_INTERVAL=10000   # 10s
# export OTEL_LOGS_EXPORT_INTERVAL=5000      # 5s

# Traces (Beta): default aus. Aktivieren erfordert den Beta-Schalter (zusätzlich
# zu CLAUDE_CODE_ENABLE_TELEMETRY=1 oben) UND einen Traces-Exporter:
# export CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1   # schaltet Span-Tracing frei (Pflicht)
# export OTEL_TRACES_EXPORTER=otlp
# Hinter einem custom ANTHROPIC_BASE_URL (Gateway) wird der traceparent-Header per
# Default NICHT propagiert – dann zusätzlich:
# export CLAUDE_CODE_PROPAGATE_TRACEPARENT=1

# ── Relevante Metriken (Auswahl) ─────────────────────────────────────────────
#   claude_code.token.usage          – Tokens, aufschlüsselbar nach
#                                       model / skill.name / agent.name / user
#   claude_code.cost.usage           – Kosten in USD (Schätzung, s. o.)
#   claude_code.lines_of_code.count  – hinzugefügte/entfernte Zeilen
#   claude_code.commit.count         – Commits
#   claude_code.pull_request.count   – PRs
#   claude_code.session.count        – Sessions
#   claude_code.active_time.total    – aktive Zeit
# Events: tool_decision, skill_activated, api_error
# (claude_code.hook ist ein Trace-Span, kein Event – nur bei aktivem Beta-Tracing)
