# Kopiere diese Datei nach .env.local und trage echte Werte ein (.env.local ist gitignored).

# Neon Postgres – Pooled Connection String, Region Frankfurt/EU.
# Neon-Dashboard → Project → Connect → "Pooled connection" (Host enthält "-pooler").
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require"

# Auth.js Secret (Folge-Task Auth). Erzeugen: npx auth secret  ODER  openssl rand -base64 32
AUTH_SECRET="change-me"
