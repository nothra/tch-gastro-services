# Vorlage für die stage-spezifischen Env-Dateien (alle gitignored außer dieser .example):
#   .env.local  → DEV  (lokale Docker-DB)          – für pnpm dev / db:migrate / db:seed
#   .env.int    → INT  (Neon-INT-DB)               – für pnpm db:migrate:int / db:seed:int
#   .env.prd    → PRD  (Neon-Produktions-DB)       – für pnpm db:migrate:prd (vorsichtig!)
# Auf Vercel werden dieselben Variablen im Dashboard je Environment/Branch gesetzt.

# ── Stage-Kennung (steuert Banner, Icon, Titel) ──────────────────────────────
# dev | int | prd   (NEXT_PUBLIC_* ist im Client sichtbar)
NEXT_PUBLIC_STAGE="dev"

# ── Datenbank ────────────────────────────────────────────────────────────────
# DEV (lokal, Docker – siehe docker-compose.yml):
DATABASE_URL="postgresql://tch:tch@localhost:5432/tch_dev"
# INT/PRD (Neon Pooled, Region Frankfurt): Host enthält "-pooler", z. B.
#   postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Erzeugen: openssl rand -base64 32   (NICHT `npx auth secret` – zieht das falsche CLI)
AUTH_SECRET="change-me"

# ── Initial-Admin für pnpm db:seed / db:seed:int ─────────────────────────────
SEED_ADMIN_EMAIL="admin@tch.example"
SEED_ADMIN_PASSWORD="change-me"
