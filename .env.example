# Vorlage für die stage-spezifischen Env-Dateien (alle gitignored außer dieser .example):
#   .env.local  → DEV  (lokale Docker-DB)     – für pnpm dev / db:migrate / db:seed
#   .env.int    → INT  (Neon-Branch von PRD)  – für db:migrate:int / db:seed:int / db:anonymize:int
#   .env.prd    → PRD  (Neon-Produktions-DB)  – für pnpm db:migrate:prd (vorsichtig!)
# Auf Vercel werden dieselben Variablen im Dashboard je Environment/Branch gesetzt.
#
# WICHTIG: Werte OHNE Anführungszeichen eintragen (dotenv / node --env-file brauchen keine).
# Falls doch Quotes, nur GERADE ASCII-Quotes ("). NIEMALS typografische Anführungszeichen
# wie U+201C/U+201D – Copy-Paste aus Dashboards/Doku schleust diese leicht ein und bricht
# die DB-Verbindung (Header-Fehler "ByteString ... > 255").

# ── Stage-Kennung (steuert Banner, Icon, Titel) ──────────────────────────────
# Pro Datei setzen: .env.local=dev · .env.int=int · .env.prd=prd
# (NEXT_PUBLIC_* wird zur Build-Zeit inlined und ist im Client sichtbar.)
NEXT_PUBLIC_STAGE=dev

# ── Datenbank ────────────────────────────────────────────────────────────────
# DEV (.env.local) – lokal, Docker (siehe docker-compose.yml):
DATABASE_URL=postgresql://tch:tch@localhost:5432/tch_dev
# INT (.env.int) / PRD (.env.prd) – Neon Pooled, Region Frankfurt. Host enthält "-pooler";
# der von Neon kopierte String darf zusätzliche Parameter enthalten (sslmode, channel_binding), z. B.:
#   postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Erzeugen: openssl rand -base64 32   (NICHT `npx auth secret` – zieht das falsche CLI)
AUTH_SECRET=change-me

# ── Initial-Admin für pnpm db:seed / db:seed:int ─────────────────────────────
SEED_ADMIN_EMAIL=admin@tch.example
SEED_ADMIN_PASSWORD=change-me
