# Factory-Template .gitignore

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/settings.json
*.iml

# Logs
*.log
logs/

# Temporäre Factory-Dateien
tasks/pipeline-stuck-*.md

# Generierte Metrik-Reports (Snapshots, jederzeit regenerierbar via /daily-metrics).
# Das append-only tasks/interrupt-log.jsonl ist BEWUSST nicht ignoriert –
# es ist die persistente Quelle der Autonomie-Rate und gehört in die Historie.
tasks/metrics-*.md

# Projekt-spezifisch (nach init-factory.sh anpassen)
# target/
# node_modules/
# dist/
# build/
# .env
# .env.local
