# Factory-Template .gitignore

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/settings.json
*.iml

# Logs
*.log
logs/

# Temporäre Factory-Dateien
tasks/pipeline-stuck-*.md

# Generierte Metrik-Reports (Snapshots, jederzeit regenerierbar via /daily-metrics).
# Das append-only tasks/interrupt-log.jsonl ist BEWUSST nicht ignoriert –
# es ist die persistente Quelle der Autonomie-Rate und gehört in die Historie.
tasks/metrics-*.md

# ─── Next.js / Node-App (TCH Gastro Services) ────────────────────────────────
# dependencies
/node_modules
/.pnp
.pnp.*

# testing / coverage
/coverage

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
pnpm-debug.log*

# env files (Secrets: DATABASE_URL, AUTH_SECRET etc. – nie committen)
.env*
# ... außer der Beispiel-Vorlage (ohne echte Werte):
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright (E2E)
/test-results
/playwright-report
/blob-report
/playwright/.cache

# misc
*.pem
